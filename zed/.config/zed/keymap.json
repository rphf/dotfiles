[
  // Globals
  {
    "bindings": {
      "cmd-e": "project_panel::ToggleFocus",
      "cmd-g": "git_panel::ToggleFocus",
    },
  },
  // Tubro console.log
  {
    "context": "Editor && (extension==js || extension==jsx || extension==ts || extension==tsx )",
    "bindings": {
      "cmd-l": [
        "workspace::SendKeystrokes",
        "escape v i w y o console.log(`🚀[DEBUG] space ~ space cmd-v :`,  space cmd-v ) escape",
      ],
    },
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // Circle between open tabs
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-l": "pane::ActivateNextItem",
      // put key-bindings here if you want them to work only in normal mode
    },
  },
  // In references/search multibuffers, gd opens the file at the excerpt under the cursor
  {
    "context": "Editor && vim_mode == normal && multibuffer && !VimWaiting && !menu",
    "bindings": {
      "g d": "editor::OpenExcerpts",
    },
  },
  // Circle between terminal tabs, mirroring the editor ctrl-h/ctrl-l bindings.
  // Note: this overrides the shell's ctrl-l (clear) and ctrl-h (backspace); use cmd-k to clear.
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-l": "pane::ActivateNextItem",
    },
  },
]
