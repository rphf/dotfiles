{
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "zed",
  },
  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "Cursor",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "GitHub Dark",
  },
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14.5,
  "buffer_font_weight": 300,
  "buffer_line_height": {
    "custom": 1.4,
  },
  "vim_mode": true,
  "cursor_blink": false,
  "show_signature_help_after_edits": true,
  "go_to_definition_fallback": "find_all_references", // gd jumps to def, falls back to references when none (Cursor-like)
  "expand_excerpt_lines": 5, // The default number of lines to expand excerpts in the multibuffer by.
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "vertical_scroll_margin": 30, // keep the cursor in the center
  "use_smartcase_search": true, // case sensitive search if there is any uppercase letter
  "project_panel": {
    "dock": "left",
    "entry_spacing": "standard",
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
  },
  "selection_highlight": false,
  "languages": {
    "TypeScript": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
    "TSX": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
    "JavaScript": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
  },
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "formatter": "auto",
  "file_finder": {
    "modal_max_width": "large",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "journal": {
    "path": "~",
    "hour_format": "hour24",
  },
  "terminal": {
    "button": true,
    "line_height": "standard",
    "font_size": 14,
    "font_family": "JetBrainsMono Nerd Font Mono",
  },
  "code_actions_on_format": {},
  "tasks": {
    "variables": {},
    "enabled": true,
  },
  "auto_install_extensions": {
    "html": true,
    "ruby": true,
    "lua": true,
    "graphql": true,
    "github-theme": true,
    "tsgo": true,
  },
  "vim": {
    "default_mode": "normal",
    "toggle_relative_line_numbers": false,
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": false,
    "custom_digraphs": {},
  },
}
