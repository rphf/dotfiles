{
  "cli_default_open_behavior": "new_window",
  "base_keymap": "Cursor",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "GitHub Dark",
  },
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14.5,
  "buffer_font_weight": 300,
  "buffer_line_height": {
    "custom": 1.4,
  },
  "vim_mode": true,
  "cursor_blink": false,
  "show_signature_help_after_edits": true,
  "diff_view_style": "unified", // show diffs inline (full width) instead of split side-by-side
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "vertical_scroll_margin": 30, // keep the cursor in the center
  "use_smartcase_search": true, // case sensitive search if there is any uppercase letter
  "project_panel": {
    "dock": "left",
    "entry_spacing": "standard",
  },
  "agent": {
    "dock": "right",
  },
  "selection_highlight": false,
  "languages": {
    "TypeScript": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
    "TSX": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
    "JavaScript": {
      "language_servers": [
        "vtsls",
        "!typescript-language-server",
        "!tsgo",
        "...",
      ],
    },
  },
  "autosave": "on_focus_change",
  "file_finder": {
    "modal_max_width": "large",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "journal": {
    "hour_format": "hour24",
  },
  "terminal": {
    "font_size": 14,
    "font_family": "JetBrainsMono Nerd Font Mono",
  },
  "vim": {
    "use_system_clipboard": "on_yank",
  },
  "auto_install_extensions": {
    "ruby": true,
    "lua": true,
    "graphql": true,
    "github-theme": true,
    "tsgo": true,
  },
}
